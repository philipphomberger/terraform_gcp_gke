# Server
HOMBOX_PORT=8080
HOMBOX_BASE_URL=http://localhost:8080
HOMBOX_ENV=development

# Database
DATABASE_URL=postgres://hombox:hombox@localhost:5432/hombox?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hombox-files
S3_DERIVATIVES_BUCKET=hombox-derivatives
S3_USE_SSL=false

# Session
SESSION_SECRET=change-me-to-a-random-64-char-string
SESSION_MAX_AGE=604800  # 7 days in seconds

# WebAuthn
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:8080
WEBAUTHN_RP_DISPLAY_NAME=Hombox

# OIDC Providers (comma-separated provider names)
OIDC_PROVIDERS=google,github
# Per-provider config via env:
# OIDC_GOOGLE_CLIENT_ID=...
# OIDC_GOOGLE_CLIENT_SECRET=...
# OIDC_GITHUB_CLIENT_ID=...
# OIDC_GITHUB_CLIENT_SECRET=...

# Upload limits
UPLOAD_MAX_SIMPLE_SIZE=104857600      # 100MB
UPLOAD_MAX_MULTIPART_SIZE=53687091200 # 50GB
UPLOAD_ANONYMOUS_MAX_SIZE=524288000   # 500MB
UPLOAD_CHUNK_SIZE=5242880             # 5MB default chunk size
